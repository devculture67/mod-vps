# rairu-kun MOD Environment Variables
# Copy to .env and fill in your values

# ============ BORE TUNNELS ============
BORE_TOKEN=your_bore_token_here
BORE_SERVER=bore.pub
BORE_PORT=3977

# ============ BOT CONFIG ============
BOT_PASSWORD=rairukun2025

# Bot 1 - Telegram Webhook
BOT_TOKEN_1=your_bot_token_1_here
WEBHOOK_URL_1=https://your-bore-subdomain.bore.pub

# Bot 2 - HTTP API
BOT_TOKEN_2=your_bot_token_2_here
WEBHOOK_URL_2=https://your-bore-subdomain.bore.pub

# Bot 3 - File Manager
BOT_TOKEN_3=your_bot_token_3_here
WEBHOOK_URL_3=https://your-bore-subdomain.bore.pub

# Bot 4 - System Control
BOT_TOKEN_4=your_bot_token_4_here
WEBHOOK_URL_4=https://your-bore-subdomain.bore.pub

# Authorized users for System Control Bot (comma-separated chat IDs)
AUTHORIZED_USERS=123456789,987654321

# ============ REGION ============
REGION=ap